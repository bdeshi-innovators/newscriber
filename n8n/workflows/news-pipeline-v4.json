    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nlet rawContent = input.choices[0].message.content || '';\nrawContent = rawContent.replace(/^```(?:json)?\\n/i, '').replace(/\\n```$/i, '').trim();\n\nlet decision;\ntry {\n  decision = JSON.parse(rawContent);\n} catch (e) {\n  throw new Error(`Failed to parse LLM response as JSON. Raw content: ${JSON.stringify(rawContent)}`);\n}\nlet fps = decision.selected_fingerprints;\nif (!Array.isArray(fps)) fps = [];\n\nconst maxArticles = $('Build Editor Payload').first().json.max_articles || 10;\nconst selectedFps = new Set(fps.slice(0, maxArticles));\n\n// Fetch the original items from Postgres node to get the full bodies back\nconst allItems = $('Postgres: Read raw articles').all();\nconst selected = allItems.filter(i => i.json.fingerprint && selectedFps.has(i.json.fingerprint));\n\nconst capped = selected.slice(0, maxArticles);\nconst targetLength = Math.max(30, Math.floor(350 / Math.max(1, capped.length)));\nreturn capped.map(i => ({ json: { ...i.json, target_length: targetLength } }));"
      },
