      "parameters": {
        "method": "POST",
        "url": "https://api.firecrawl.dev/v2/scrape",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"url\": \"{{ $json.url }}\",\n  \"formats\": [\"markdown\", \"links\"],\n  \"onlyMainContent\": true\n}",
        "options": {}
      },
      "id": "fc-index",
      "name": "Firecrawl: scrape index",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "FIRECRAWL_CRED",
          "name": "Firecrawl API Key"
        }
      },
      "continueOnFail": true,
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst source = $('Source list').first().json.source;\nconst links = (data.data && data.data.links) ? data.data.links : [];\nconst MAX_ARTICLES = 25;\n\nconst hash = (s) => {\n  let h = 0x811c9dc5;\n  for (let i = 0; i < s.length; i++) {\n    h ^= s.charCodeAt(i);\n    h = Math.imul(h, 0x01000193);\n  }\n  return (h >>> 0).toString(16);\n};\n\nreturn links.slice(0, MAX_ARTICLES).map(url => ({\n  json: { url, source_name: source, fingerprint: hash(url) }\n}));"
      },
