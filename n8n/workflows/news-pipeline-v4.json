      "id": "editor-rank",
      "name": "Editor: Select & Rank",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1300,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "AZURE_OPENAI_CRED",
