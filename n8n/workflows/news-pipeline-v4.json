      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO news_items (fingerprint, headline, body, source_name, article_url, language, scraped_at) VALUES ('{{ $node[\"Per article\"].json.fingerprint }}', '{{ $json.data.metadata.title.replace(/'/g, \"''\") }}', '{{ $json.data.markdown.replace(/'/g, \"''\") }}', '{{ $node[\"Per article\"].json.source_name }}', '{{ $node[\"Per article\"].json.url }}', 'en', NOW()) ON CONFLICT (fingerprint) DO NOTHING;"
      },
