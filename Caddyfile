# To enable HTTPS:
# 1. Replace ':80' with your domain name (e.g., api.voicescribe.com)
# 2. Ensure your domain points to this server's public IP.
# 3. Caddy will automatically handle Let's Encrypt certificates.
:80 {
    # Webhook App
    handle_path /api/* {
        reverse_proxy webhook-app:8080
    }

    # n8n
    handle {
        reverse_proxy n8n:5678 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    log {
        output stdout
    }
}
