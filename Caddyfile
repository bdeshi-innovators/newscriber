# Production Block (with Automatic HTTPS)
newscriber.unityflow.ai {
    # Webhook App routes
    @webhook_routes {
        path /api/* /visualizer* /trigger* /publish* /episodes*
    }
    handle @webhook_routes {
        reverse_proxy webhook-app:8080
    }

    # Storage Proxy (Minio locally, Cloudflare R2 in prod)
    handle_path /storage/* {
        reverse_proxy {$STORAGE_UPSTREAM:minio:9000} {
            header_up Host {$STORAGE_HOST:minio:9000}
        }
    }

    # n8n
    handle {
        reverse_proxy n8n:5678 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    log {
        output stdout
    }
}

# Local Development Block (Strictly HTTP, no HTTPS redirects!)
http://localhost, http://127.0.0.1 {
