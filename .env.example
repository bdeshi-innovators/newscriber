# VoiceScribe — environment overrides for docker compose
# Copy to `.env` (`cp .env.example .env`) and edit for production.
# Compose interpolates ${VAR:-default}, so all values below are optional.

# ─── Postgres ────────────────────────────────────────────────
POSTGRES_USER=voicescribe
POSTGRES_PASSWORD=voicescribe         # CHANGE for production
POSTGRES_DB=voicescribe

# ─── Host-side port mappings (chosen to avoid common collisions) ─
DB_HOST_PORT=55432
WEBHOOK_HOST_PORT=18080
N8N_HOST_PORT=15678

# ─── Webhook service ─────────────────────────────────────────
LOG_LEVEL=info                        # debug | info | warn | error
LOG_FORMAT=json                       # json | text
IMAGE_TAG=latest

# ─── n8n ─────────────────────────────────────────────────────
# Current n8n uses an owner-account setup on first run (visit /setup).
# For production: complete owner setup, then restrict the host port
# binding (e.g. set N8N_HOST_PORT to 127.0.0.1:15678 in a reverse-proxy setup).
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:15678/
N8N_API_TOKEN=                # n8n Public API token
TZ=UTC
FIRECRAWL_API_KEY=

# ─── LLM (Azure OpenAI / Kimi-K2.5) ─────────────────────────────
AZURE_OPENAI_ENDPOINT=https://devel-mnww3344-eastus2.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=Kimi-K2.5
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_KEY=
